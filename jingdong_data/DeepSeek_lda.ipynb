   "source": [
    "from gensim import corpora\n",
    "import gensim\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.decomposition import LatentDirichletAllocation\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "from gensim.models import CoherenceModel\n",
    "from tqdm import tqdm\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "import os\n",
    "os.environ[\"TOKENIZERS_PARALLELISM\"] = \"false\"\n",
    "\n",
    "\n",
    "from transformers import AutoTokenizer, AutoModel\n",
    "# 下载1.5B轻量版（适合普通PC）ollama run deepseek-r1:1.5b 
    "bert_tokenizer = AutoTokenizer.from_pretrained("deepseek-ai/deepseek-r1-7b")\n",
    "bert_model = AutoModel.from_pretrained("deepseek-ai/deepseek-r1-7b", output_hidden_states=True)\n",
    "\n",
    "# 加载预训练的中文Word2Vec模型（例如，腾讯的中文词向量）\n",
    "word_vectors = gensim.models.KeyedVectors.load_word2vec_format('tencent-ailab-embedding-zh-d100-v0.2.0-s/tencent-ailab-embedding-zh-d100-v0.2.0-s.txt', binary=False)\n",
    "print('加载模型腾讯word2vec成功')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "bert_model.eval()\n",
    "bert_model = bert_model.to(device)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 创建文档向量\n",
    "@torch.no_grad()\n",
    "def document2vector(doc,name2idx):\n",
    "    return_vector = np.zeros(len(name2idx))\n",
    "    doc_dict = bert_tokenizer(doc,padding='longest',return_tensors='pt',max_length=500,truncation=True)\n",
    "    doc_dict = {k:v.to(device) for k,v in doc_dict.items()}\n",
    "    with torch.no_grad():\n",
    "        doc_embed = bert_model(doc_dict['input_ids'],doc_dict['attention_mask'])\\\n",
    "            .last_hidden_state.mean(dim=1).detach()\n",
    "    words = doc.split(' ')\n",
    "    words = [word for word in words if word in name2idx.keys() and len(word)>1]\n",
    "    if len(words) <= 0 :\n",
    "        return return_vector\n",
    "    \n",
    "    word_dict = bert_tokenizer(words,padding='longest',return_tensors='pt',max_length=500,truncation=True)    \n",
    "    word_dict = {k:v.to(device) for k,v in word_dict.items()}\n",
    "    with torch.no_grad():\n",
    "        word_embed = bert_model(word_dict['input_ids'],word_dict['attention_mask'])\\\n",
    "            .last_hidden_state.mean(dim=1).detach()\n",
    "        # 计算余弦相似度\n",
    "        cosine_similarities = F.cosine_similarity(word_embed, doc_embed, dim=1)\n",
    "    sims = cosine_similarities.detach().cpu().numpy()\n",
    "    for word , sim in zip(words,sims):\n",
    "        return_vector[name2idx[word]] = sim\n",
    "    return return_vector\n",
    "\n",
    "def tokenize(text):\n",
    "    return text.split(' ')\n",
    "\n",
    "topic_num = 5\n",
    "num_words_per_topic = 10 # 每个主题内的关键词数量\n",
    "with open(f'data/clean_sentence_v2.txt','r') as file:\n",
    "    documents = [line.strip().split(',')[1] for line in file.readlines()]\n",
    "\n",
    "# 构建词表\n",
    "vectorizer = TfidfVectorizer(tokenizer=tokenize,max_features=5000)\n",
    "X = vectorizer.fit_transform(documents)\n",
    "feature_names = vectorizer.get_feature_names_out()\n",
    "feature2idx = {feature:idx for idx,feature in enumerate(feature_names)}"
   ]
  },
